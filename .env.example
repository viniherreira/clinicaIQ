# Database (Supabase recomendado para produção; Docker local para dev)
# Supabase → Project Settings → Database → Connection string:
#   DATABASE_URL = pooler "Transaction" (porta 6543) + ?pgbouncer=true&connection_limit=1
#   DIRECT_URL   = pooler "Session" (porta 5432), usada pelas migrations
DATABASE_URL="postgresql://postgres.[REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DIRECT_URL="postgresql://postgres.[REF]:[SENHA]@aws-0-[REGIAO].pooler.supabase.com:5432/postgres"

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# Encryption (LGPD)
ENCRYPTION_MASTER_KEY=generate-a-64-char-hex-key-here

# WhatsApp (Meta Cloud API)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_PROVIDER=mock

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379
