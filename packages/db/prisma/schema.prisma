generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooler (Supabase Transaction mode, port 6543) — used by the app at runtime.
  url       = env("DATABASE_URL")
  // Direct/session connection (port 5432) — used by `prisma db push`/migrations.
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  OWNER
  ADMIN
  RECEPTIONIST
  PROFESSIONAL
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  RESCHEDULED
  CANCELLED
  ATTENDED
  MISSED
}

enum AppointmentType {
  PARTICULAR
  CONVENIO
  CORTESIA
}

enum QuoteStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum DiscountType {
  PERCENT
  FIXED
}

enum ToothStatus {
  TO_TREAT
  IN_TREATMENT
  TREATED
  EXTRACTED
  MISSING
}

// ─── Models ──────────────────────────────────────────────

model Tenant {
  id         String   @id @default(cuid())
  clerkOrgId String   @unique
  name       String
  slug       String   @unique
  document   String?
  phone      String?
  email      String?
  address    String?
  logoUrl    String?
  settings   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  users               User[]
  patients            Patient[]
  professionals       Professional[]
  procedures          Procedure[]
  procedureCategories ProcedureCategory[]
  appointments        Appointment[]
  quotes              Quote[]
  messages            WhatsAppMessage[]
  auditLogs           AuditLog[]
  blockedSlots        BlockedSlot[]
  patientNotes        PatientNote[]
  toothRecords        ToothRecord[]
  payments            Payment[]
  anamneses           Anamnesis[]
  evolutions          Evolution[]
  patientFiles        PatientFile[]
  whatsappSession     WhatsAppSession?

  @@map("tenants")
}

model User {
  id          String   @id @default(cuid())
  tenantId    String
  clerkUserId String   @unique
  name        String
  email       String
  role        Role     @default(RECEPTIONIST)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  patientNotes PatientNote[]
  auditLogs    AuditLog[]

  @@index([tenantId])
  @@map("users")
}

model Patient {
  id              String    @id @default(cuid())
  tenantId        String
  controlNumber   Int
  name            String
  nickname        String?
  cpfEncrypted    String?   @map("cpf")
  phoneEncrypted  String    @map("phone")
  phone2Encrypted String?   @map("phone2")
  email           String?
  birthDate       DateTime?
  gender          String?
  maritalStatus   String?
  profession      String?
  referredBy      String?
  notes           String?
  zipCode         String?
  street          String?
  addressNumber   String?
  complement      String?
  neighborhood    String?
  city            String?
  state           String?
  lgpdConsentAt   DateTime?
  active          Boolean   @default(true)
  deletedAt       DateTime?
  createdById     String?
  updatedById     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  patientNotes PatientNote[]
  appointments Appointment[]
  quotes       Quote[]
  messages     WhatsAppMessage[]
  toothRecords ToothRecord[]
  payments     Payment[]
  anamnesis    Anamnesis?
  evolutions   Evolution[]
  files        PatientFile[]

  @@unique([tenantId, controlNumber])
  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, deletedAt])
  @@map("patients")
}

model PatientNote {
  id        String   @id @default(cuid())
  tenantId  String
  patientId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([patientId, createdAt(sort: Desc)])
  @@map("patient_notes")
}

model Professional {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?  @unique
  name      String
  specialty String?
  color     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant       Tenant                 @relation(fields: [tenantId], references: [id])
  schedules    ProfessionalSchedule[]
  appointments Appointment[]
  blockedSlots BlockedSlot[]
  procedures   Procedure[]            @relation("ProcedureProfessionals")
  evolutions   Evolution[]

  @@index([tenantId])
  @@map("professionals")
}

model ProfessionalSchedule {
  id             String  @id @default(cuid())
  professionalId String
  dayOfWeek      Int
  startTime      String
  endTime        String
  lunchStart     String?
  lunchEnd       String?

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@map("professional_schedules")
}

model ProcedureCategory {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  color     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  procedures Procedure[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("procedure_categories")
}

model Procedure {
  id                 String   @id @default(cuid())
  tenantId           String
  categoryId         String?
  name               String
  description        String?
  basePrice          Decimal  @db.Decimal(10, 2)
  durationMinutes    Int
  prepTimeMinutes    Int?
  color              String?
  internalCode       String?
  materials          String?
  allowsDiscount     Boolean  @default(false)
  maxDiscountPercent Decimal? @db.Decimal(5, 2)
  active             Boolean  @default(true)
  deletedAt          DateTime?
  createdById        String?
  updatedById        String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant        Tenant             @relation(fields: [tenantId], references: [id])
  category      ProcedureCategory? @relation(fields: [categoryId], references: [id])
  professionals Professional[]     @relation("ProcedureProfessionals")
  appointments  Appointment[]
  quoteItems    QuoteItem[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@index([tenantId, deletedAt])
  @@index([tenantId, categoryId])
  @@map("procedures")
}

model Appointment {
  id             String            @id @default(cuid())
  tenantId       String
  patientId      String
  professionalId String
  procedureId    String?
  startTime      DateTime
  endTime        DateTime
  status         AppointmentStatus @default(SCHEDULED)
  type           AppointmentType   @default(PARTICULAR)
  notes          String?
  cancelReason   String?
  createdById    String?
  updatedById    String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  patient      Patient           @relation(fields: [patientId], references: [id])
  professional Professional      @relation(fields: [professionalId], references: [id])
  procedure    Procedure?        @relation(fields: [procedureId], references: [id])
  messages     WhatsAppMessage[]

  @@index([tenantId, professionalId, startTime])
  @@index([tenantId, startTime])
  @@index([tenantId, status])
  @@map("appointments")
}

model BlockedSlot {
  id             String   @id @default(cuid())
  tenantId       String
  professionalId String
  startTime      DateTime
  endTime        DateTime
  reason         String?
  createdAt      DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([tenantId, professionalId, startTime])
  @@map("blocked_slots")
}

model Quote {
  id            String       @id @default(cuid())
  tenantId      String
  patientId     String
  number        Int
  publicToken   String       @unique @default(cuid())
  status        QuoteStatus  @default(DRAFT)
  discountType  DiscountType @default(PERCENT)
  discountValue Decimal      @default(0) @db.Decimal(10, 2)
  subtotal      Decimal      @db.Decimal(10, 2)
  total         Decimal      @db.Decimal(10, 2)
  notes         String?
  internalNotes String?
  validUntil    DateTime
  sentAt        DateTime?
  viewedAt      DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  rejectReason  String?
  pdfUrl        String?
  createdById   String?
  updatedById   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  tenant   Tenant            @relation(fields: [tenantId], references: [id])
  patient  Patient           @relation(fields: [patientId], references: [id])
  items    QuoteItem[]
  messages WhatsAppMessage[]
  payments Payment[]

  @@unique([tenantId, number])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("quotes")
}

model QuoteItem {
  id              String   @id @default(cuid())
  quoteId         String
  procedureId     String?
  name            String
  description     String?
  unitPrice       Decimal  @db.Decimal(10, 2)
  quantity        Int      @default(1)
  discountPercent Decimal? @default(0) @db.Decimal(5, 2)
  total           Decimal  @db.Decimal(10, 2)

  quote     Quote      @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  procedure Procedure? @relation(fields: [procedureId], references: [id])

  @@index([quoteId])
  @@map("quote_items")
}

model WhatsAppMessage {
  id            String           @id @default(cuid())
  tenantId      String
  patientId     String
  appointmentId String?
  quoteId       String?
  direction     MessageDirection
  templateName  String?
  content       String
  status        MessageStatus    @default(PENDING)
  externalId    String?
  sentAt        DateTime?
  deliveredAt   DateTime?
  readAt        DateTime?
  errorMessage  String?
  createdAt     DateTime         @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  patient     Patient      @relation(fields: [patientId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])
  quote       Quote?       @relation(fields: [quoteId], references: [id])

  @@index([tenantId, appointmentId])
  @@index([tenantId, patientId, createdAt(sort: Desc)])
  @@index([externalId])
  @@map("whatsapp_messages")
}

model ToothRecord {
  id          String      @id @default(cuid())
  tenantId    String
  patientId   String
  toothNumber Int
  status      ToothStatus
  note        String?
  updatedById String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@unique([patientId, toothNumber])
  @@index([tenantId, patientId])
  @@map("tooth_records")
}

/** Health questionnaire (one per patient). Answers stored as JSON:
 *  { items: { [key]: { value: 'yes'|'no', detail?: string } }, obs?: string } */
model Anamnesis {
  id          String   @id @default(cuid())
  tenantId    String
  patientId   String   @unique
  answers     Json
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([tenantId])
  @@map("anamneses")
}

/** Clinical evolution entry — what was done in a visit/session. */
model Evolution {
  id             String   @id @default(cuid())
  tenantId       String
  patientId      String
  professionalId String?
  description    String
  teeth          Int[]    @default([])
  createdById    String?
  createdAt      DateTime @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  patient      Patient       @relation(fields: [patientId], references: [id])
  professional Professional? @relation(fields: [professionalId], references: [id])

  @@index([tenantId, patientId, createdAt(sort: Desc)])
  @@map("evolutions")
}

/** Image/document attached to a patient (stored in Supabase Storage). */
model PatientFile {
  id          String   @id @default(cuid())
  tenantId    String
  patientId   String
  bucketPath  String
  filename    String
  mimeType    String
  sizeBytes   Int
  description String?
  createdById String?
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])

  @@index([tenantId, patientId, createdAt(sort: Desc)])
  @@map("patient_files")
}

model Payment {
  id          String   @id @default(cuid())
  tenantId    String
  patientId   String
  quoteId     String?
  amount      Decimal  @db.Decimal(10, 2)
  method      String?
  notes       String?
  paidAt      DateTime @default(now())
  createdById String?
  createdAt   DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  patient Patient @relation(fields: [patientId], references: [id])
  quote   Quote?  @relation(fields: [quoteId], references: [id])

  @@index([tenantId, patientId, paidAt(sort: Desc)])
  @@map("payments")
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  userId    String?
  action    String
  entity    String
  entityId  String
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User?  @relation(fields: [userId], references: [id])

  @@index([tenantId, entity, entityId])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("audit_logs")
}

/// Lifecycle of a clinic's own WhatsApp line, paired over the WhatsApp Web
/// protocol (QR code). One line per tenant.
enum WhatsAppConnectionStatus {
  DISCONNECTED
  CONNECTING
  QR_PENDING
  CONNECTED
  ERROR
}

model WhatsAppSession {
  id       String                   @id @default(cuid())
  tenantId String                   @unique
  status   WhatsAppConnectionStatus @default(DISCONNECTED)

  /// Number the clinic paired, in E.164 digits (no mask). Filled on connect.
  phoneNumber String?
  displayName String?

  /// Short-lived pairing payload. Cleared as soon as the socket is open.
  qrCode      String?
  qrExpiresAt DateTime?

  lastError      String?
  connectedAt    DateTime?
  disconnectedAt DateTime?

  /// Which automations this clinic wants on its own line.
  notifyOnCreate  Boolean @default(true)
  notifyReminder  Boolean @default(true)
  notifyBirthday  Boolean @default(false)
  birthdayMessage String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([status])
  @@map("whatsapp_sessions")
}

/// Baileys credential store. One row per (tenant, key); values are encrypted
/// with the tenant-scoped master key, never logged.
model WhatsAppAuthKey {
  id       String @id @default(cuid())
  tenantId String
  key      String
  value    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
  @@map("whatsapp_auth_keys")
}
