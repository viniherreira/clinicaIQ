{
  "name": "clinicaiq",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "pnpm --filter @clinicaiq/db generate",
    "db:push": "pnpm --filter @clinicaiq/db push",
    "db:seed": "pnpm --filter @clinicaiq/db seed",
    "worker": "tsx --env-file=.env apps/web/worker.ts"
  },
  "devDependencies": {
    "turbo": "^2",
    "prettier": "^3",
    "tsx": "^4"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "node": ">=20"
  }
}
